{% if section.settings.video != blank or section.settings.image != blank %}
  <div class="full-bleed-media">
    {% if section.settings.video != blank %}
      {{ section.settings.video | video_tag: image_size: '2880x', loop: true, controls: false, muted: true, autoplay: true }}
    {% else %}
      {{ section.settings.image | image_url: width: 2880 | image_tag  }}
    {% endif %}

    {% if section.settings.desktop_heading != blank %}
      <h1 class="mobile-hidden big-h1">{{ section.settings.desktop_heading }}</h1>
    {% endif %}
  </div>
{% endif %}

{% stylesheet %}
  .full-bleed-media {
    width: 100%;
    height: 100vh;
    position: relative;
  }
  .full-bleed-media :is(video, img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .full-bleed-media h1 {
    color: var(--white);
    position: absolute;
    top: 6.75rem;
    left: 50%;
    transform: translateX(-50%);
  }

  @media screen and (min-width: 990px) {
    .full-bleed-media h1 {
      top: 50%;
      left: unset;
      transform: translateY(-50%);
      padding: 0 2.5rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Full Bleed Media",
  "disabled_on": {"groups": ["header", "footer"]},
  "settings": [
    {
      "type": "text",
      "id": "desktop_heading",
      "label": "Desktop heading"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video",
      "info": "If video field blank, image field used instead."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
  ],
  "presets": [
    {
      "name": "Full Bleed Media"
    }
  ]
}
{% endschema %}
