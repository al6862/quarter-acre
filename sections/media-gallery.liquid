<div class="media-gallery">
  {% if section.settings.left_content != blank or section.settings.right_content != blank %}
    <div class="media-gallery__content">
      {% if section.settings.left_content != blank %}
        <div class="rte">
          {{ section.settings.left_content }}
        </div>
      {% endif %}
      {% if section.settings.right_content != blank %}
        <div class="rte">
          {{ section.settings.right_content }}
        </div>
      {% endif %}
    </div>
  {% endif %}
  <div class="media-gallery__slides">
    {% for block in section.blocks %}
      <div class="media-gallery__slide">
        {% if block.settings.link != blank %}
          <a href="{{ block.settings.link }}">
        {% endif %}

          {% if block.settings.video != blank %}
            {{ block.settings.video | video_tag: image_size: '676x', loop: true, controls: false, muted: true, autoplay: true }}
          {% elsif block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 676 | image_tag }}
          {% endif %}

        {% if block.settings.link != blank %}
          </a>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>

{% stylesheet %}
  .media-gallery {
    margin-top: 2.5rem;
    border-top: 1px solid var(--light-brown-60);
    padding: 2.5rem 0 0;
  }
  @media screen and (min-width: 990px) {
    .media-gallery {
      margin-top: 1.25rem;
      padding: 1.25rem 1.25rem 0;
    }
  }
  .media-gallery__content {
    display: flex;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }
  @media screen and (max-width: 989px) {
    .media-gallery__content {
      padding: 0 1.25rem;
    }
  }
  .media-gallery__slides {
    display: flex;
    gap: 1rem;
  }
  @media screen and (max-width: 989px) {
    .media-gallery__slides {
      padding: 0 1.25rem;
      overflow-x: auto;
      scrollbar-width: none;
      scroll-snap-type: x mandatory;
      scroll-padding-left: 1.25rem;
      display: flex;
      flex-wrap: nowrap;
      gap: .75rem;
      position: relative;
    }
  }
  @media screen and (max-width: 989px) {
    .media-gallery__slide {
      width: 37vw;
      flex-shrink: 0;
      scroll-snap-align: start;
    }
  }
  @media screen and (min-width: 990px) {
    .media-gallery__slide {
      flex: 1;
    }
  }

  .media-gallery__slide :is(img, video) {
    aspect-ratio: 338 / 599;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Media Gallery",
  "disabled_on": {"groups": ["header", "footer"]},
  "settings": [
    {
      "type": "richtext",
      "id": "left_content",
      "label": "Left content"
    },
    {
      "type": "richtext",
      "id": "right_content",
      "label": "Right content"
    },
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "limit": 4,
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Video",
          "info": "If video field blank, image field used instead."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link",
        },
      ]
    },
  ],
  "presets": [
    {
      "name": "Media Gallery"
    }
  ]
}
{% endschema %} 
