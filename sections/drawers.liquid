{% if section.blocks.size > 0 %}
  <drawers-element class="drawers">
    <div class="drawers-element__desktop mobile-hidden">
      <div class="drawers-element__headings">
        {% for block in section.blocks %}
          {% if block.settings.heading != blank %}
            <span class="chart drawers-element__heading{% if forloop.index0 == 0 %} active{% endif %}" data-index="{{ forloop.index0 }}">{{ block.settings.heading }}</span>
          {% endif %}
        {% endfor %}
        <span class="marker"></span>
      </div>
      <div class="drawers-element__blocks">
        {% for block in section.blocks %}
          <div class="drawers-element__block" data-index="{{ forloop.index0 }}">
            {% if block.settings.content != blank %}
              <div class="drawers-element__content rte body-bold">{{ block.settings.content }}</div>
            {% endif %}
            {% if block.settings.first_video != blank or block.settings.first_image != blank or block.settings.second_video != blank or block.settings.second_image != blank %}
              <div class="drawers-element__images">
                {% if block.settings.first_video != blank or block.settings.first_image != blank %}
                  <div class="drawers-element__first-image">
                    {% if block.settings.first_video != blank %}
                      {{ block.settings.first_video | video_tag: image_size: '1980x', loop: true, controls: false, muted: true, autoplay: true }}
                    {% elsif block.settings.first_image != blank %}
                      {{ block.settings.first_image | image_url: width: 1980 | image_tag }}
                    {% endif %}

                    {% if block.settings.first_caption != blank %}
                      <span class="drawers-element__first-image-caption">
                        <span class="fig">(e)</span>
                        <span>{{ block.settings.first_caption }}</span>
                      </span>
                    {% endif %}
                    {% if block.settings.first_image_content != blank %}
                      <div class="drawers-element__first-image-content">
                        {{ block.settings.first_image_content }}
                      </div>
                    {% endif %}
                  </div>
                {% endif %}
                {% if block.settings.second_video != blank or block.settings.second_image != blank %}
                  <div class="drawers-element__second-image">
                    {% if block.settings.second_video != blank %}
                      {{ block.settings.second_video | video_tag: image_size: '1980x', loop: true, controls: false, muted: true, autoplay: true }}
                    {% elsif block.settings.second_image != blank %}
                      {{ block.settings.second_image | image_url: width: 1980 | image_tag }}
                    {% endif %}

                    {% if block.settings.second_caption != blank %}
                      <span class="drawers-element__second-image-caption">
                        <span class="fig">(e)</span>
                        <span>{{ block.settings.second_caption }}</span>
                      </span>
                    {% endif %}
                    {% if block.settings.second_image_content != blank %}
                      <div class="drawers-element__second-image-content">
                        {{ block.settings.second_image_content }}
                      </div>
                    {% endif %}
                  </div>
                {% endif %}
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
    <div class="drawers-element__mobile desktop-hidden">
      {% for block in section.blocks %}
        {% if block.settings.heading != blank %}
          <details>
            <summary class="chart drawers-element__heading">
              {{ block.settings.heading }}
              {{ 'icon-open.svg' | inline_asset_content }}
            </summary>
            <div class="drawers-element__container">
              <div class="drawers-element__content-images-container">
                <div class="drawers-element__content-images">
                  {% if block.settings.content != blank %}
                    <div class="drawers-element__content rte body">{{ block.settings.content }}</div>
                  {% endif %}
                  {% if block.settings.first_video != blank or block.settings.first_image != blank %}
                    <div class="drawers-element__first-image">
                      {% if block.settings.first_video != blank %}
                        {{ block.settings.first_video | video_tag: image_size: '1980x', loop: true, controls: false, muted: true, autoplay: true }}
                      {% elsif block.settings.first_image != blank %}
                        {{ block.settings.first_image | image_url: width: 1980 | image_tag }}
                      {% endif %}

                      {% if block.settings.first_caption != blank %}
                        <span class="drawers-element__first-image-caption">
                          <span class="fig">(e)</span>
                          <span>{{ block.settings.first_caption }}</span>
                        </span>
                      {% endif %}
                      {% if block.settings.first_image_content != blank %}
                        <div class="drawers-element__first-image-content">
                          {{ block.settings.first_image_content }}
                        </div>
                      {% endif %}
                    </div>
                  {% endif %}
                  {% if block.settings.second_video != blank or block.settings.second_image != blank %}
                    <div class="drawers-element__second-image">
                      {% if block.settings.second_video != blank %}
                        {{ block.settings.second_video | video_tag: image_size: '1980x', loop: true, controls: false, muted: true, autoplay: true }}
                      {% elsif block.settings.second_image != blank %}
                        {{ block.settings.second_image | image_url: width: 1980 | image_tag }}
                      {% endif %}

                      {% if block.settings.second_caption != blank %}
                        <span class="drawers-element__second-image-caption">
                          <span class="fig">(e)</span>
                          <span>{{ block.settings.second_caption }}</span>
                        </span>
                      {% endif %}
                      {% if block.settings.second_image_content != blank %}
                        <div class="drawers-element__second-image-content">
                          {{ block.settings.second_image_content }}
                        </div>
                      {% endif %}
                    </div>
                  {% endif %}
                </div>
              </div>
            </div>
          </details>
        {% endif %}
      {% endfor %}
    </div>
  </drawers-element>
{% endif %}

{% style %}
  .drawers {
    display: block;
    margin-top: 3.75rem;
    border-top: 1px solid var(--light-brown-60);
    padding: 3.75rem 1.25rem 0;
  }
  @media screen and (min-width: 990px) {
    .drawers {
      margin-top: 1.25rem;
      padding: 3.75rem 1.25rem 2.5rem;
    }
  }

  .drawers-element__desktop {
    display: flex;
    align-items: start;
    gap: 8.625rem;
  }

  .drawers-element__desktop .drawers-element__heading {
    display: block;
    padding-right: 8.75rem;
    line-height: 2.75rem;
    border-top: 1px solid var(--light-brown-30);
    color: var(--grey);
    text-wrap: nowrap;
    cursor: pointer;
    transition: color 300ms ease-out, border 300ms ease-out;
  }
  .drawers-element__desktop .drawers-element__heading.active {
    border-top: 1px solid var(--light-brown);
    color: var(--color-foreground);
  }
  .drawers-element__desktop .drawers-element__headings {
    position: sticky;
    top: var(--header-height);
  }
  .drawers-element__desktop .drawers-element__headings .marker {
    display: block;
    width: 0.5625rem;
    height: 0.5625rem;
    border-radius: 50%;
    background-color: var(--dark-brown);
    position: absolute;
    top: calc(1.375rem + 1px - 0.5 * 0.5625rem);
    right: 0;
    transition: top 300ms ease-out;
  }

  .drawers-element__desktop .drawers-element__blocks {
    display: flex;
    flex-direction: column;
    gap: 5rem;
  }
  .drawers-element__desktop .drawers-element__block {
    scroll-margin-top: var(--header-height);
    border-top: 1px solid var(--light-brown);
    padding: 1.25rem 0 0;
  }
  .drawers-element__desktop .drawers-element__content {
    margin-bottom: 2.5rem;
  }
  .drawers-element__desktop .drawers-element__images {
    display: grid;
    grid-template-columns: repeat(20, minmax(0, 1fr));
    gap: 1.25rem;
  }
  .drawers-element__desktop .drawers-element__block:not(:has(.drawers-element__first-image-content)):has(.drawers-element__second-image-content) .drawers-element__first-image {
    grid-column: 1 / span 11;
  }
  .drawers-element__desktop .drawers-element__block:not(:has(.drawers-element__first-image-content)):has(.drawers-element__second-image-content) .drawers-element__second-image {
    grid-column: 12 / span 9;
  }
  .drawers-element__desktop .drawers-element__block:not(:has(.drawers-element__second-image-content)):has(.drawers-element__first-image-content) .drawers-element__first-image {
    grid-column: 1 / span 9;
  }
  .drawers-element__desktop .drawers-element__block:not(:has(.drawers-element__second-image-content)):has(.drawers-element__first-image-content) .drawers-element__second-image {
    grid-column: 10 / span 11;
  }
  .drawers-element__desktop .drawers-element__block:has(.drawers-element__first-image-content):has(.drawers-element__second-image-content) .drawers-element__first-image {
    grid-column: 1 / span 10;
  }
  .drawers-element__desktop .drawers-element__block:has(.drawers-element__first-image-content):has(.drawers-element__second-image-content) .drawers-element__second-image {
    grid-column: 11 / span 10;
  }
  .drawers-element__desktop :is(.drawers-element__first-image-caption, .drawers-element__second-image-caption) {
    display: flex;
    justify-content: space-between;
    margin-top: 0.75rem;
  }
  .drawers-element__desktop :is(.drawers-element__first-image-content, .drawers-element__second-image-content) {
    margin-top: 1.25rem;
  }

  .drawers-element__mobile details {
    border-top: 1px solid var(--light-brown-30)
  }
  .drawers-element__mobile details summary {
    cursor: pointer;
  }
  .drawers-element__mobile details summary::marker {
    display: none;
  }
  .drawers-element__mobile .drawers-element__heading {
    padding: 1.25rem 0;
    display: flex;
    justify-content: space-between;
  }

  .drawers-element__mobile .drawers-element__container {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 300ms ease-out;
    overflow: hidden;
  }
  .drawers-element__mobile .drawers-element__content-images-container {
    min-height: 0;
  }
  .drawers-element__mobile details[open] .drawers-element__container {
    grid-template-rows: 1fr;
  }
  .drawers-element__mobile details.closing .drawers-element__container {
    grid-template-rows: 0fr;
  }
  .drawers-element__mobile details .icon-open .plus-line {
    transition: opacity 300ms ease-out;
  }
  .drawers-element__mobile details[open] .icon-open .plus-line {
    opacity: 0;
  }

  .drawers-element__mobile .drawers-element__content-images {
    padding: 1.25rem 0;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }
  .drawers-element__mobile :is(.drawers-element__first-image-caption, .drawers-element__second-image-caption) {
    margin-top: 0.75rem;
    display: flex;
    justify-content: space-between;
  }
  .drawers-element__mobile .drawers-element__second-image {
    width: 70%;
  }
  .drawers-element__mobile :is(.drawers-element__first-image-content, .drawers-element__second-image-content) {
    margin-top: 1.25rem;
  }


  .drawers img {
    width: 100%;
    object-fit: cover;
    aspect-ratio: 453 / 575;
  }
{% endstyle %}

{% schema %}
{
  "name": "Drawers",
  "disabled_on": {"groups": ["header", "footer"]},
  "blocks": [
    {
      "type": "drawer",
      "name": "Drawer",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content"
        },
        {
          "type": "header",
          "content": "First Media"
        },
        {
          "type": "video",
          "id": "first_video",
          "label": "First Video",
          "info": "If left blank, image used instead."
        },
        {
          "type": "image_picker",
          "id": "first_image",
          "label": "First Image"
        },
        {
          "type": "text",
          "id": "first_caption",
          "label": "First Caption"
        },
        {
          "type": "richtext",
          "id": "first_image_content",
          "label": "First Image Content"
        },
        {
          "type": "header",
          "content": "Second Media"
        },
        {
          "type": "video",
          "id": "second_video",
          "label": "Second Video",
          "info": "If left blank, image used instead."
        },
        {
          "type": "image_picker",
          "id": "second_image",
          "label": "Second Image"
        },
        {
          "type": "text",
          "id": "second_caption",
          "label": "Second Caption"
        },
        {
          "type": "richtext",
          "id": "second_image_content",
          "label": "Second Image Content"
        },
      ]
    },
  ],
  "presets": [
    {
      "name": "Drawers"
    }
  ]
}
{% endschema %} 